    "navigation": {
        "tagQueryMapping": {
            "default": {
                "mode": "rawParam",
                "param": "tag_id",
                "valueSource": "tagId",
                "requiredPattern": "^\\d+$"
            }
        }
    },
    "searchForm": {
        "urlPattern": "search",
        "params": {
            "query": {
                "queryParam": "query",
                "type": "text",
                "placeholder": "Search galleries...",
                "label": "Search"
            },
            "sort": {
                "queryParam": "sort",
                "type": "sort",
                "label": "Sort by",
                "options": [
                    {
                        "value": "date",
                        "label": "Recent"
                    },
                    {
                        "value": "popular",
                        "label": "Popular"
                    },
                    {
                        "value": "popular-week",
                        "label": "Popular This Week"
                    },
                    {
                        "value": "popular-today",
                        "label": "Popular Today"
                    }
                ]
            }
        }
    },
