        "mirrors": [
            "https://nhentai.xxx",
            "https://nhentai.to"
        ],
        "useMirrors": false
    },
    "auth": {
        "enabled": true,
        "mode": "tokenApi",
        "authorizationScheme": "User",
        "powAction": "login",
        "commentPowAction": "comment",
        "endpoints": {
            "pow": "/api/v2/pow",
            "captcha": "/api/v2/captcha",
            "login": "/api/v2/auth/login",
            "refresh": "/api/v2/auth/refresh",
            "logout": "/api/v2/auth/logout",
            "favorites": "/api/v2/favorites",
            "galleryFavorite": "/api/v2/galleries/{gallery_id}/favorite",
            "galleryComments": "/api/v2/galleries/{gallery_id}/comments",
            "blacklist": "/api/v2/blacklist",
            "blacklistIds": "/api/v2/blacklist/ids",
            "user": "/api/v2/user"
        },
        "fields": {
            "username": "username",
            "password": "password",
            "commentBody": "body",
            "captchaResponse": "captcha_response",
            "powChallenge": "pow_challenge",
            "powNonce": "pow_nonce",
            "powAction": "pow_action",
            "accessToken": "access_token",
            "refreshToken": "refresh_token",
            "expiresIn": "expires_in",
            "tokenType": "token_type"
        }
    },
