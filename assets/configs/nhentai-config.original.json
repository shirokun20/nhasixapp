    "api": {
        "enabled": true,
        "apiBase": "https://nhentai.net",
        "timeout": 30000,
        "endpoints": {
            "galleryDetail": "/api/v2/galleries/{id}?include=comments",
            "allGalleries": "/api/v2/galleries?page={page}",
            "search": "/api/v2/search?query={query}&sort={sort}&page={page}",
            "tagSearch": "/api/v2/galleries/tagged?tag_id={tagId}&page={page}",
            "related": "/api/v2/galleries/{id}/related",
            "comments": "/api/v2/galleries/{id}?include=comments",
            "contentUrl": "/g/{id}/",
            "random": "/api/v2/galleries/random"
