    "api": {
        "enabled": true,
        "apiBase": "https://nhentai.net/api/v2",
        "timeout": 30000,
        "endpoints": {
            "galleryDetail": "/api/v2/galleries/{id}?include=comments",
            "allGalleries": "/api/v2/galleries?page={page}",
            "search": "/api/v2/search?query={query}&sort={sort}&page={page}",
            "tagSearch": "/api/v2/galleries/tagged?tag_id={tagId}&page={page}",
            "related": "/api/v2/galleries/{id}/related",
            "comments": "/api/v2/galleries/{id}?include=comments",
            "contentUrl": "/g/{id}/",
            "random": "/api/v2/galleries/random"
        },
        "mirrors": [
            "https://nhentai.xxx",
            "https://nhentai.to"
        ],
        "useMirrors": false
    },
    "selectors": {
        "items": {
            "selector": "$.result[*]",
            "type": "jsonpath"
        },
        "totalPages": {
            "selector": "$.num_pages",
            "type": "jsonpath"
        },
        "currentPage": {
            "selector": "$.page",
            "type": "jsonpath"
        },
        "id": {
            "selector": "$.id",
            "type": "jsonpath"
        },
        "title": {
            "selector": "$.title.english",
            "type": "jsonpath"
        },
        "listTitle": {
