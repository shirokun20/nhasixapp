        "detailJapaneseTitle": {
            "selector": "$.title.japanese",
            "type": "jsonpath"
        },
        "mediaId": {
            "selector": "$.media_id",
            "type": "jsonpath"
        },
        "tagIds": {
            "selector": "$.tag_ids[*]",
            "type": "jsonpath"
        },
        "pageCount": {
            "selector": "$.num_pages",
            "type": "jsonpath"
        },
        "favorites": {
            "selector": "$.num_favorites",
            "type": "jsonpath"
        },
        "uploadDate": {
            "selector": "$.upload_date",
            "type": "jsonpath"
        },
        "tags": {
            "selector": "$.tags[?(@.type=='tag')].name",
            "type": "jsonpath"
        },
        "tagObjects": {
            "selector": "$.tags[*]",
            "type": "jsonpath"
        },
        "artists": {
            "selector": "$.tags[?(@.type=='artist')].name",
            "type": "jsonpath"
        },
        "characters": {
            "selector": "$.tags[?(@.type=='character')].name",
            "type": "jsonpath"
        },
        "parodies": {
            "selector": "$.tags[?(@.type=='parody')].name",
            "type": "jsonpath"
        },
        "groups": {
            "selector": "$.tags[?(@.type=='group')].name",
            "type": "jsonpath"
        },
        "language": {
            "selector": "$.tags[?(@.type=='language' && @.name!='translated')].name",
            "type": "jsonpath"
        },
        "listThumbnailPath": {
            "selector": "$.thumbnail",
            "type": "jsonpath"
        },
        "detailCoverPath": {
            "selector": "$.cover.path",
            "type": "jsonpath"
        },
        "detailThumbnailPath": {
            "selector": "$.thumbnail.path",
            "type": "jsonpath"
        },
        "imagePaths": {
