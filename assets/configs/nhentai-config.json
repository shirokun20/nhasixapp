        "commentId": {
            "selector": "$.id",
            "type": "jsonpath"
        },
        "commentUsername": {
            "selector": "$.poster.username",
            "type": "jsonpath"
        },
        "commentBody": {
            "selector": "$.body",
            "type": "jsonpath"
        },
        "commentAvatarUrl": {
            "selector": "$.poster.avatar_url",
            "type": "jsonpath"
        },
        "commentPostDate": {
            "selector": "$.post_date",
            "type": "jsonpath"
        }
    },
    "navigation": {
        "tagQueryMapping": {
            "default": {
                "mode": "rawParam",
                "param": "tag_id",
                "valueSource": "tagId",
                "requiredPattern": "^\\d+$"
            }
        }
    },
    "searchConfig": {
        "searchMode": "query-string",
        "endpoint": "/search/",
        "queryParam": "q",
        "queryTokenTemplates": {
            "include": "{type}:\"{name}\"",
            "exclude": "-{type}:\"{name}\""
        },
        "filterSupport": {
            "singleSelect": [
                "language",
                "category"
            ],
            "multiSelect": [
                "tag",
                "artist",
                "character",
                "parody",
                "group"
            ],
            "supportsExclude": true
        },
        "sortingConfig": {
            "allowDynamicReSort": true,
            "defaultSort": "newest",
            "widgetType": "dropdown",
            "options": [
                {
                    "value": "newest",
                    "apiValue": "date",
                    "label": "Recent",
                    "displayLabel": "Sorted by: Recent",
                    "icon": "update",
                    "isDefault": true
                },
                {
                    "value": "popular",
                    "apiValue": "popular",
                    "label": "Popular",
                    "displayLabel": "Sorted by: Most Popular",
                    "icon": "trending_up"
                },
                {
                    "value": "popular-week",
                    "apiValue": "popular-week",
                    "label": "Popular This Week",
                    "displayLabel": "Sorted by: Popular This Week",
                    "icon": "date_range"
                },
                {
                    "value": "popular-today",
                    "apiValue": "popular-today",
                    "label": "Popular Today",
                    "displayLabel": "Sorted by: Popular Today",
                    "icon": "today"
                }
            ],
            "messages": {
                "dropdownLabel": "Sort by:",
                "noOptionsAvailable": "No sorting options"
            }
        },
        "pagination": {
            "urlPattern": "/search/?q={query}&page={page}",
            "paramName": "page"
        }
    },
    "network": {
        "rateLimit": {
            "enabled": true,
            "requestsPerMinute": 60,
            "minDelayMs": 200,
            "cooldownDurationMs": 300000
        },
        "retry": {
            "maxAttempts": 3,
            "delayMs": 1000,
            "exponentialBackoff": true
        },
        "cloudflare": {
            "bypassEnabled": true,
            "antiDetection": true
        },
        "headers": {
            "User-Agent": "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7",
            "Accept-Language": "en-US,en;q=0.9",
            "Accept-Encoding": "gzip, deflate",
            "DNT": "1",
            "Upgrade-Insecure-Requests": "1",
            "Sec-Fetch-Dest": "document",
            "Sec-Fetch-Mode": "navigate",
            "Sec-Fetch-Site": "none",
            "Sec-Fetch-User": "?1",
            "Cache-Control": "max-age=0",
            "Referer": "https://nhentai.net/"
        }
    },
    "features": {
