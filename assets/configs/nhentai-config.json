{
    "source": "nhentai",
    "version": "1.0.3",
    "lastUpdated": "2026-03-01T00:00:00+07:00",
    "configUrl": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/assets/configs/nhentai-config.json",
    "baseUrl": "https://nhentai.net",
    "avatarBaseUrl": "https://i3.nhentai.net",
    "api": {
        "enabled": true,
        "timeout": 30000,
        "endpoints": {
            "galleryDetail": "/api/gallery/{id}",
            "allGalleries": "/api/galleries/all?page={page}",
            "search": "/api/galleries/search?query={query}&page={page}&sort={sort}",
            "tagSearch": "/api/galleries/tagged?tag_id={tagId}&page={page}",
            "related": "/api/gallery/{id}/related",
            "comments": "/api/gallery/{id}/comments",
            "contentUrl": "/g/{id}/"
        },
        "images": {
            "fullSize": "https://i.nhentai.net/galleries/{mediaId}/{page}.{ext}",
            "thumbnail": "https://t.nhentai.net/galleries/{mediaId}/thumb.{ext}",
            "cover": "https://t.nhentai.net/galleries/{mediaId}/cover.{ext}",
            "pageThumbnail": "https://t.nhentai.net/galleries/{mediaId}/{page}t.{ext}"
        },
        "extensionMapping": {
            "j": "jpg",
            "p": "png",
            "g": "gif",
            "w": "webp"
        },
        "mirrors": [
            "https://nhentai.xxx",
            "https://nhentai.to"
        ],
        "useMirrors": false
    },
    "selectors": {
        "items": {
            "selector": "$.result[*]",
            "type": "jsonpath"
        },
        "totalPages": {
            "selector": "$.num_pages",
            "type": "jsonpath"
        },
        "currentPage": {
            "selector": "$.page",
            "type": "jsonpath"
        },
        "id": {
            "selector": "$.id",
            "type": "jsonpath"
        },
        "title": {
            "selector": "$.title.english",
            "type": "jsonpath"
        },
        "englishTitle": {
            "selector": "$.title.english",
            "type": "jsonpath"
        },
        "japaneseTitle": {
            "selector": "$.title.japanese",
            "type": "jsonpath"
        },
        "mediaId": {
            "selector": "$.media_id",
            "type": "jsonpath"
        },
        "pageCount": {
            "selector": "$.num_pages",
            "type": "jsonpath"
        },
        "uploadDate": {
            "selector": "$.upload_date",
            "type": "jsonpath"
        },
        "tags": {
            "selector": "$.tags[?(@.type=='tag')].name",
            "type": "jsonpath"
        },
        "tagObjects": {
            "selector": "$.tags[*]",
            "type": "jsonpath"
        },
        "artists": {
            "selector": "$.tags[?(@.type=='artist')].name",
            "type": "jsonpath"
        },
        "characters": {
            "selector": "$.tags[?(@.type=='character')].name",
            "type": "jsonpath"
        },
        "parodies": {
            "selector": "$.tags[?(@.type=='parody')].name",
            "type": "jsonpath"
        },
        "groups": {
            "selector": "$.tags[?(@.type=='group')].name",
            "type": "jsonpath"
        },
        "language": {
            "selector": "$.tags[?(@.type=='language' && @.name!='translated')].name",
            "type": "jsonpath"
        },
        "coverUrlBuilder": {
            "mediaIdSelector": "$.media_id",
            "coverExtSelector": "$.images.pages[0].t",
            "preferWebpSuffix": true,
            "template": "https://t.nhentai.net/galleries/{mediaId}/thumb.{ext}",
            "extensionMapping": {
                "j": "jpg",
                "p": "png",
                "g": "gif",
                "w": "webp"
            }
        },
        "imageUrlBuilder": {
            "mediaIdSelector": "$.media_id",
            "pageExtSelector": "$.images.pages[*].t",
            "template": "https://i.nhentai.net/galleries/{mediaId}/{page}.{ext}",
            "extensionMapping": {
                "j": "jpg",
                "p": "png",
                "g": "gif",
                "w": "webp"
            }
        },
        "comments": {
            "selector": "$[*]",
            "type": "jsonpath"
        },
        "commentId": {
            "selector": "$.id",
            "type": "jsonpath"
        },
        "commentUsername": {
            "selector": "$.poster.username",
            "type": "jsonpath"
        },
        "commentBody": {
            "selector": "$.body",
            "type": "jsonpath"
        },
        "commentAvatarUrl": {
            "selector": "$.poster.avatar_url",
            "type": "jsonpath"
        },
        "commentPostDate": {
            "selector": "$.post_date",
            "type": "jsonpath"
        }
    },
    "searchConfig": {
        "searchMode": "query-string",
        "endpoint": "/search/",
        "queryParam": "q",
        "queryTokenTemplates": {
            "include": "{type}:\"{name}\"",
            "exclude": "-{type}:\"{name}\""
        },
        "filterSupport": {
            "singleSelect": [
                "language",
                "category"
            ],
            "multiSelect": [
                "tag",
                "artist",
                "character",
                "parody",
                "group"
            ],
            "supportsExclude": true
        },
        "sortingConfig": {
            "allowDynamicReSort": true,
            "defaultSort": "newest",
            "widgetType": "dropdown",
            "options": [
                {
                    "value": "newest",
                    "apiValue": "",
                    "label": "Recent",
                    "displayLabel": "Sorted by: Recent",
                    "icon": "update",
                    "isDefault": true
                },
                {
                    "value": "popular",
                    "apiValue": "popular",
                    "label": "Popular",
                    "displayLabel": "Sorted by: Most Popular",
                    "icon": "trending_up"
                },
                {
                    "value": "popular-week",
                    "apiValue": "popular-week",
                    "label": "Popular This Week",
                    "displayLabel": "Sorted by: Popular This Week",
                    "icon": "date_range"
                },
                {
                    "value": "popular-today",
                    "apiValue": "popular-today",
                    "label": "Popular Today",
                    "displayLabel": "Sorted by: Popular Today",
                    "icon": "today"
                }
            ],
            "messages": {
                "dropdownLabel": "Sort by:",
                "noOptionsAvailable": "No sorting options"
            }
        },
        "pagination": {
            "urlPattern": "/search/?q={query}&page={page}",
            "paramName": "page"
        }
    },
    "network": {
        "rateLimit": {
            "enabled": true,
            "requestsPerMinute": 60,
            "minDelayMs": 200,
            "cooldownDurationMs": 300000
        },
        "retry": {
            "maxAttempts": 3,
            "delayMs": 1000,
            "exponentialBackoff": true
        },
        "cloudflare": {
            "bypassEnabled": true,
            "antiDetection": true
        },
        "headers": {
            "User-Agent": "AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.7",
            "Accept-Language": "en-US,en;q=0.9",
            "Accept-Encoding": "gzip, deflate",
            "DNT": "1",
            "Upgrade-Insecure-Requests": "1",
            "Sec-Fetch-Dest": "document",
            "Sec-Fetch-Mode": "navigate",
            "Sec-Fetch-Site": "none",
            "Sec-Fetch-User": "?1",
            "Cache-Control": "max-age=0",
            "Referer": "https://nhentai.net/"
        }
    },
    "features": {
        "search": true,
        "related": true,
        "download": true,
        "favorite": true,
        "chapters": false,
        "bookmark": false,
        "comments": true,
        "supportsTagExclusion": true,
        "supportsAdvancedSearch": true,
        "generatePdf": true,
        "offlineMode": true,
        "maintenanceFeatures": {}
    },
    "ui": {
        "displayName": "NHentai",
        "iconPath": "assets/icons/nhentai.png",
        "themeColor": "#d43726",
        "cardStyle": "standard",
        "openInBrowserUrl": "https://nhentai.net"
    }
}