<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="id.nhasix.kuron_native.kuron_native">
  <application>
      <activity
          android:name=".WebViewActivity"
          android:theme="@style/Theme.AppCompat.Light.NoActionBar"
          android:windowSoftInputMode="adjustResize"/>
        <activity
          android:name=".CaptchaWebViewActivity"
          android:theme="@style/Theme.AppCompat.Light.NoActionBar"
          android:windowSoftInputMode="adjustResize"/>
      <activity
          android:name=".pdf.PdfReaderActivity"
          android:theme="@style/Theme.AppCompat.NoActionBar"
          android:screenOrientation="portrait"
          android:configChanges="orientation|keyboardHidden|screenSize"/>
        <provider
          android:name="androidx.core.content.FileProvider"
          android:authorities="${applicationId}.kuron_native.fileprovider"
          android:exported="false"
          android:grantUriPermissions="true">
          <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/kuron_native_file_paths" />
        </provider>
  </application>
</manifest>
