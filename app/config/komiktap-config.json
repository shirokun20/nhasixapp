{
  "source": "komiktap",
  "version": "1.1.2",
  "enabled": true,
  "defaultLanguage": "indonesian",
  "configUrl": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/app/config/komiktap-config.json",
  "baseUrl": "https://komiktap.info",
  "ui": {
    "displayName": "KomikTap",
    "iconPath": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/app/images/komiktap.png",
    "brandColor": "#4CAF50"
  },
  "network": {
    "requiresBypass": false,
    "headers": {
      "Referer": "https://komiktap.info/",
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
    }
  },
  "scraper": {
    "enabled": true,
    "urlPatterns": {
      "home": {
        "url": "/",
        "list": {
          "container": ".utao",
          "fields": {
            "id": {
              "selector": "a.series",
              "attribute": "href",
              "transform": "slug"
            },
            "title": {
              "selector": ".luf > a > h4"
            },
            "coverUrl": {
              "selector": "img.ts-post-image",
              "attribute": "src"
            }
          },
          "pagination": {
            "alt": ".hpage a.r"
          }
        }
      },
      "homePage": {
        "url": "/page/{page}/",
        "inherits": "home"
      },
      "search": {
        "url": "/?s={query}&paged={page}",
        "list": {
          "container": "div.bsx",
          "fields": {
            "id": {
              "selector": "a[href]",
              "attribute": "href",
              "transform": "slug"
            },
            "title": {
              "selector": ".tt"
            },
            "coverUrl": {
              "selector": ".limit img",
              "attribute": "src"
            }
          },
          "pagination": {
            "next": ".pagination .next.page-numbers"
          }
        }
      },
      "genreSearch": {
        "url": "/genres/{tag}/",
        "inherits": "search"
      },
      "genreSearchPage": {
        "url": "/genres/{tag}/page/{page}/",
        "inherits": "search"
      },
      "detail": "/manga/{id}/",
      "chapter": "/{id}/"
    },
    "selectors": {
      "detail": {
        "fields": {
          "title": {
            "selector": ".entry-title"
          },
          "coverUrl": {
            "selector": ".thumb img",
            "attribute": "src"
          },
          "publishedDate": {
            "selector": "time[itemprop='datePublished']",
            "attribute": "datetime"
          },
          "uploadDate": {
            "selector": "time[itemprop='dateModified']",
            "attribute": "datetime"
          },
          "tags": {
            "selector": ".seriestugenre a",
            "multi": true
          }
        },
        "chapters": {
          "container": "#chapterlist li",
          "fields": {
            "id": {
              "selector": ".chbox .eph-num a",
              "attribute": "href",
              "transform": "slug"
            },
            "title": {
              "selector": ".chbox .chapternum"
            },
            "date": {
              "selector": ".chbox .chapterdate"
            }
          }
        },
        "comments": {
          "container": "#comments .comment-list > li.comment",
          "fields": {
            "id": {
              "selector": "a.comment-reply-link",
              "attribute": "data-commentid"
            },
            "username": {
              "selector": ".comment-author .fn"
            },
            "body": {
              "selector": "p"
            },
            "avatarUrl": {
              "selector": ".comment-author img",
              "attribute": "src"
            },
            "postDate": {
              "selector": ".comment-meta a"
            }
          }
        }
      },
      "reader": {
        "tsReaderRegex": "ts_reader\\.run\\((.*?)\\);",
        "container": "#readerarea",
        "images": {
          "selector": "img",
          "attribute": "src"
        },
        "nav": {
          "next": ".nextprev a.next, .nav-links a.next, .ch-next-btn",
          "prev": ".nextprev a.prev, .nav-links a.prev, .ch-prev-btn"
        }
      }
    }
  },
  "searchForm": {
    "urlPattern": "search",
    "params": {
      "query": {
        "queryParam": "s",
        "type": "text",
        "placeholder": "Cari komik..."
      },
      "page": {
        "queryParam": "paged",
        "type": "page"
      },
      "genre": {
        "queryParam": "genre",
        "type": "tag",
        "urlPattern": "genreSearch"
      },
      "status": {
        "queryParam": "status",
        "type": "select",
        "options": [
          "ongoing",
          "completed",
          "hiatus"
        ]
      },
      "order": {
        "queryParam": "order",
        "type": "select",
        "options": [
          "update",
          "title",
          "rating",
          "popular"
        ]
      }
    }
  },
  "contentIdPattern": "/manga/([^/]+)",
  "features": {
    "comments": true,
    "related": false,
    "download": false,
    "favorite": true,
    "chapters": true
  }
}