{
    "source": "crotpedia",
    "version": "1.0.3",
    "enabled": true,
    "defaultLanguage": "indonesian",
    "configUrl": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/app/config/crotpedia-config.json",
    "baseUrl": "https://crotpedia.net",
    "ui": {
        "displayName": "Crotpedia",
        "iconPath": "https://raw.githubusercontent.com/shirokun20/nhasixapp/refs/heads/master/app/images/crotpedia.png",
        "themeColor": "#1E88E5",
        "cardStyle": "standard"
    },
    "network": {
        "requiresBypass": true,
        "cloudflare": {
            "bypassEnabled": true,
            "antiDetection": false
        },
        "headers": {
            "Referer": "https://crotpedia.net/"
        }
    },
    "auth": {
        "enabled": true,
        "loginUrl": "https://crotpedia.net/login/",
        "registerUrl": "https://crotpedia.net/register/",
        "bookmarkUrl": "https://crotpedia.net/bookmark/",
        "nonceRegex": "name=\"koi_login_nonce\"\\s+value=\"([^\"]+)\"",
        "loginSuccessFilter": "/wp-admin"
    },
    "scraper": {
        "enabled": true,
        "urlPatterns": {
            "home": {
                "url": "/",
                "list": {
                    "container": ".flexbox4-item",
                    "fields": {
                        "id": {
                            "selector": "a",
                            "attribute": "href",
                            "transform": "slug"
                        },
                        "title": {
                            "selector": ".flexbox4-side .title a"
                        },
                        "coverUrl": {
                            "selector": ".flexbox4-thumb img",
                            "attribute": "src"
                        }
                    },
                    "pagination": {
                        "current": ".pagination .page-numbers.current",
                        "next": ".pagination .next.page-numbers",
                        "prev": ".pagination .prev.page-numbers",
                        "links": ".pagination a.page-numbers:not(.next):not(.prev)"
                    }
                }
            },
            "homePage": {
                "url": "/page/{page}/",
                "inherits": "home"
            },
            "search": {
                "url": "/?s={query}",
                "list": {
                    "container": ".flexbox2-item",
                    "fields": {
                        "id": {
                            "selector": "a",
                            "attribute": "href",
                            "transform": "slug"
                        },
                        "title": {
                            "selector": ".flexbox2-title span"
                        },
                        "coverUrl": {
                            "selector": ".flexbox2-thumb img",
                            "attribute": "src"
                        }
                    },
                    "pagination": {
                        "current": ".pagination .page-numbers.current",
                        "next": ".pagination .next.page-numbers",
                        "prev": ".pagination .prev.page-numbers",
                        "links": ".pagination a.page-numbers:not(.next):not(.prev)"
                    }
                }
            },
            "searchPage": {
                "url": "/page/{page}/?s={query}",
                "inherits": "search"
            },
            "genreSearch": {
                "url": "/baca/genre/{tag}/",
                "inherits": "search"
            },
            "genreSearchPage": {
                "url": "/baca/genre/{tag}/page/{page}/",
                "inherits": "search"
            },
            "advancedSearch": {
                "url": "/advanced-search/?title={query}&order={order}&genre[]={tag}",
                "inherits": "search"
            },
            "advancedSearchPage": {
                "url": "/advanced-search/page/{page}/?title={query}&order={order}&genre[]={tag}",
                "inherits": "search"
            },
            "detail": "/baca/series/{id}/",
            "chapter": "/baca/{id}/"
        },
        "selectors": {
            "detail": {
                "fields": {
                    "title": {
                        "selector": ".series-titlex h2"
                    },
                    "coverUrl": {
                        "selector": ".series-thumb img",
                        "attribute": "src"
                    },
                    "tags": {
                        "selector": ".series-genres a",
                        "multi": true
                    }
                },
                "chapters": {
                    "container": ".series-chapterlist li",
                    "fields": {
                        "id": {
                            "selector": ".flexch-infoz a",
                            "attribute": "href",
                            "transform": "slug"
                        },
                        "title": {
                            "selector": ".flexch-infoz a span"
                        },
                        "date": {
                            "selector": ".flexch-infoz .date"
                        }
                    }
                }
            },
            "reader": {
                "container": ".reader-area",
                "images": {
                    "selector": "p img",
                    "attribute": "src"
                },
                "nav": {
                    "next": ".nextprev a.next, .nav-links a.next, a.next_page",
                    "prev": ".nextprev a.prev, .nav-links a.prev, a.prev_page"
                }
            }
        }
    },
    "searchForm": {
        "urlPattern": "advancedSearch",
        "params": {
            "query": {
                "queryParam": "title",
                "type": "text",
                "placeholder": "Cari series..."
            },
            "page": {
                "queryParam": "page",
                "type": "page"
            }
        }
    },
    "featurePages": {
        "genreList": {
            "url": "/genre-list/",
            "container": "ul.achlist li",
            "fields": {
                "name": {
                    "selector": "a",
                    "type": "text"
                },
                "url": {
                    "selector": "a",
                    "attribute": "href"
                },
                "count": {
                    "selector": "span",
                    "type": "text",
                    "transform": "int"
                }
            }
        },
        "doujinList": {
            "url": "/doujin-list/",
            "container": ".mangalist-blc a.series",
            "fields": {
                "title": {
                    "type": "text"
                },
                "url": {
                    "attribute": "href"
                },
                "id": {
                    "attribute": "rel"
                }
            }
        },
        "requestList": {
            "url": "/baca/publisher/request/",
            "pageUrl": "/baca/publisher/request/page/{page}/",
            "container": ".flexbox2-item",
            "fields": {
                "title": {
                    "selector": ".flexbox2-title span",
                    "type": "text"
                },
                "coverUrl": {
                    "selector": "img",
                    "attribute": "src"
                },
                "url": {
                    "selector": "a",
                    "attribute": "href"
                },
                "status": {
                    "selector": ".flexbox2-footer",
                    "type": "text"
                }
            }
        }
    },
    "menuConfig": {
        "genreList": {
            "enabled": true,
            "label": "Genres",
            "icon": "category"
        },
        "doujinList": {
            "enabled": true,
            "label": "Doujin List",
            "icon": "library_books"
        },
        "requestList": {
            "enabled": true,
            "label": "Request List",
            "icon": "assignment"
        }
    },
    "searchConfig": {
        "searchMode": "form-based",
        "endpoint": "/advanced-search/",
        "textFields": [
            {
                "name": "title",
                "label": "Title",
                "type": "text",
                "placeholder": "Search by title...",
                "maxLength": 100
            },
            {
                "name": "author",
                "label": "Author",
                "type": "text",
                "placeholder": "Search by author...",
                "maxLength": 100
            },
            {
                "name": "artist",
                "label": "Artist",
                "type": "text",
                "placeholder": "Search by artist...",
                "maxLength": 100
            },
            {
                "name": "yearx",
                "label": "Year",
                "type": "number",
                "min": 1900,
                "max": 2100,
                "placeholder": "e.g., 2024"
            }
        ],
        "radioGroups": [
            {
                "name": "status",
                "label": "Status",
                "options": [
                    {
                        "value": "",
                        "label": "All",
                        "isDefault": true
                    },
                    {
                        "value": "ongoing",
                        "label": "Ongoing"
                    },
                    {
                        "value": "completed",
                        "label": "Completed"
                    }
                ]
            },
            {
                "name": "type",
                "label": "Type",
                "options": [
                    {
                        "value": "",
                        "label": "All",
                        "isDefault": true
                    },
                    {
                        "value": "Manga",
                        "label": "Manga"
                    },
                    {
                        "value": "Image-set",
                        "label": "Image Set"
                    },
                    {
                        "value": "Manhwa",
                        "label": "Manhwa"
                    },
                    {
                        "value": "One-shot",
                        "label": "One Shot"
                    },
                    {
                        "value": "Doujinshi",
                        "label": "Doujinshi"
                    }
                ]
            },
            {
                "name": "order",
                "label": "Order By",
                "options": [
                    {
                        "value": "update",
                        "label": "Latest Update",
                        "isDefault": true
                    },
                    {
                        "value": "latest",
                        "label": "Latest Added"
                    },
                    {
                        "value": "popular",
                        "label": "Popular"
                    },
                    {
                        "value": "rating",
                        "label": "Rating"
                    },
                    {
                        "value": "title",
                        "label": "A-Z"
                    },
                    {
                        "value": "titlereverse",
                        "label": "Z-A"
                    }
                ]
            }
        ],
        "checkboxGroups": [
            {
                "name": "genre",
                "label": "Genre",
                "paramName": "genre[]",
                "displayMode": "expandable",
                "columns": 3,
                "loadFromTags": true,
                "tagType": "genre"
            }
        ],
        "sortingConfig": {
            "allowDynamicReSort": false,
            "defaultSort": "update",
            "widgetType": "readonly",
            "options": [
                {
                    "value": "update",
                    "apiValue": "update",
                    "label": "Latest Update",
                    "displayLabel": "Sorted by: Latest Update",
                    "icon": "update",
                    "isDefault": true
                },
                {
                    "value": "latest",
                    "apiValue": "latest",
                    "label": "Latest Added",
                    "displayLabel": "Sorted by: Latest Added",
                    "icon": "new_releases"
                },
                {
                    "value": "popular",
                    "apiValue": "popular",
                    "label": "Popular",
                    "displayLabel": "Sorted by: Most Popular",
                    "icon": "trending_up"
                },
                {
                    "value": "rating",
                    "apiValue": "rating",
                    "label": "Rating",
                    "displayLabel": "Sorted by: Highest Rating",
                    "icon": "star"
                },
                {
                    "value": "title",
                    "apiValue": "title",
                    "label": "A-Z",
                    "displayLabel": "Sorted by: A-Z",
                    "icon": "sort_by_alpha"
                },
                {
                    "value": "titlereverse",
                    "apiValue": "titlereverse",
                    "label": "Z-A",
                    "displayLabel": "Sorted by: Z-A",
                    "icon": "sort_by_alpha"
                }
            ],
            "messages": {
                "readOnlyPrefix": "Sorted by:",
                "readOnlySuffix": "🔒",
                "tapToModifyHint": "Tap to modify search filters"
            }
        }
    },
    "features": {
        "search": true,
        "chapters": true,
        "download": true,
        "favorite": false,
        "bookmark": true,
        "supportsAuth": true,
        "comments": false,
        "related": false
    }
}